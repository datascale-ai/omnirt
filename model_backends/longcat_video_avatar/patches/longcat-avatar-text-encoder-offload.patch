diff --git a/run_ascend_avatar_cp.py b/run_ascend_avatar_cp.py
index 59dcb7e..2137c33 100644
--- a/run_ascend_avatar_cp.py
+++ b/run_ascend_avatar_cp.py
@@ -167,0 +168,62 @@ def mem_gib():
+def text_encoder_device_mode():
+    return os.environ.get("LONGCAT_AVATAR_TEXT_ENCODER_DEVICE", "cpu").strip().lower()
+
+
+def text_encoder_offload_mode():
+    return os.environ.get("LONGCAT_AVATAR_TEXT_ENCODER_OFFLOAD_AFTER_PROMPT", "").strip().lower()
+
+
+def should_offload_text_encoder_after_prompt():
+    mode = text_encoder_offload_mode()
+    return mode in {"1", "true", "yes", "on", "cpu"}
+
+
+def maybe_empty_npu_cache(reset_peak=False):
+    try:
+        torch.npu.empty_cache()
+        if reset_peak:
+            torch.npu.reset_peak_memory_stats()
+    except Exception:
+        pass
+    gc.collect()
+
+
+def move_text_encoder_for_prompt(pipe, device, rank):
+    if pipe.text_encoder is None or not hasattr(pipe.text_encoder, "to"):
+        return False
+    if text_encoder_device_mode() != "npu":
+        return False
+    t0 = time.perf_counter()
+    pipe.text_encoder = pipe.text_encoder.to(device, non_blocking=True)
+    sync()
+    log(
+        {
+            "event": "text_encoder_onload_for_prompt",
+            "seconds": round(time.perf_counter() - t0, 3),
+            "mem_gib": mem_gib(),
+        },
+        rank,
+    )
+    return True
+
+
+def offload_text_encoder_after_prompt(pipe, rank):
+    if pipe.text_encoder is None or not hasattr(pipe.text_encoder, "to"):
+        return
+    if not should_offload_text_encoder_after_prompt():
+        return
+    t0 = time.perf_counter()
+    pipe.text_encoder = pipe.text_encoder.to("cpu")
+    sync()
+    maybe_empty_npu_cache(reset_peak=False)
+    log(
+        {
+            "event": "text_encoder_offloaded_after_prompt",
+            "seconds": round(time.perf_counter() - t0, 3),
+            "target": "cpu",
+            "mem_gib": mem_gib(),
+        },
+        rank,
+    )
+
+
@@ -343 +404,0 @@ def move_pipeline(pipe, args, device, rank):
-        text_device = os.environ.get("LONGCAT_AVATAR_TEXT_ENCODER_DEVICE", "cpu").strip().lower()
@@ -345 +406,2 @@ def move_pipeline(pipe, args, device, rank):
-            if text_device == "cpu":
+            text_device = text_encoder_device_mode()
+            if text_device == "cpu" or should_offload_text_encoder_after_prompt():
@@ -648,16 +710,22 @@ def broadcast_prompt_cache(pipe, args, prompt, negative_prompt, device, rank):
-        t0 = time.perf_counter()
-        cache = pipe.encode_prompt(
-            prompt=prompt,
-            negative_prompt=negative_prompt,
-            do_classifier_free_guidance=do_cfg,
-            num_videos_per_prompt=1,
-            max_sequence_length=args.max_sequence_length,
-            dtype=dtype,
-            device=device,
-        )
-        log({"event": "prompt_cache", "seconds": round(time.perf_counter() - t0, 3)}, rank)
-        if cp_size > 1:
-            for tensor in cache:
-                if tensor is not None:
-                    context_parallel_util.cp_broadcast(tensor)
-        return cache
+        move_text_encoder_for_prompt(pipe, device, rank)
+        try:
+            t0 = time.perf_counter()
+            cache = pipe.encode_prompt(
+                prompt=prompt,
+                negative_prompt=negative_prompt,
+                do_classifier_free_guidance=do_cfg,
+                num_videos_per_prompt=1,
+                max_sequence_length=args.max_sequence_length,
+                dtype=dtype,
+                device=device,
+            )
+            log({"event": "prompt_cache", "seconds": round(time.perf_counter() - t0, 3)}, rank)
+            offload_text_encoder_after_prompt(pipe, rank)
+            if cp_size > 1:
+                for tensor in cache:
+                    if tensor is not None:
+                        context_parallel_util.cp_broadcast(tensor)
+            return cache
+        except Exception:
+            offload_text_encoder_after_prompt(pipe, rank)
+            raise
